#version 430 core

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(r32ui, binding = 0) uniform uimage2D depthBuffer;

void main() {
    ivec2 coords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(depthBuffer);
    
    if (coords.x < size.x && coords.y < size.y) {
        imageStore(depthBuffer, coords, uvec4(0xFFFFFFFF));
    }
}
